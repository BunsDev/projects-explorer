#!/usr/bin/env bash
#
# Pre-commit hook: blocks commits that contain secrets or credentials.
# Portable across macOS and Linux (uses grep -E, no GNU extensions).
#
# Install: git config core.hooksPath .githooks
# Bypass (emergencies only): git commit --no-verify
#

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FAILED=0
WARNINGS=""

# ── 1. Block .env files (except .env.example) ──────────────────────────
while IFS= read -r file; do
  [ -z "$file" ] && continue
  case "$file" in
    *.env.example) ;;
    *.env|*.env.*|.env)
      WARNINGS="${WARNINGS}\n  ${RED}✗${NC} ${BOLD}${file}${NC} — env file with potential secrets"
      FAILED=1
      ;;
  esac
done <<< "$STAGED_FILES"

# ── 2. Block known credential filenames ─────────────────────────────────
while IFS= read -r file; do
  [ -z "$file" ] && continue
  basename=$(basename "$file")
  case "$basename" in
    credentials.json|service-account.json|serviceAccountKey.json)
      WARNINGS="${WARNINGS}\n  ${RED}✗${NC} ${BOLD}${file}${NC} — credential file"
      FAILED=1 ;;
    gcloud-credentials.json|.npmrc|.pypirc)
      WARNINGS="${WARNINGS}\n  ${RED}✗${NC} ${BOLD}${file}${NC} — credential file"
      FAILED=1 ;;
    id_rsa|id_rsa.pub|id_ed25519|id_ed25519.pub|id_dsa)
      WARNINGS="${WARNINGS}\n  ${RED}✗${NC} ${BOLD}${file}${NC} — SSH key"
      FAILED=1 ;;
    *.pem|*.key|*.p12|*.pfx|*.jks|*.keystore)
      WARNINGS="${WARNINGS}\n  ${RED}✗${NC} ${BOLD}${file}${NC} — key/certificate file"
      FAILED=1 ;;
  esac
done <<< "$STAGED_FILES"

# ── 3. Scan staged diffs for secret patterns ────────────────────────────
DIFF=$(git diff --cached -U0 --no-color 2>/dev/null || true)
ADDED_LINES=$(echo "$DIFF" | grep -E '^\+[^+]' || true)

if [ -z "$ADDED_LINES" ]; then
  if [ "$FAILED" -eq 1 ]; then
    echo ""
    echo -e "${RED}${BOLD}🚫 COMMIT BLOCKED — potential secrets detected${NC}"
    echo -e "$WARNINGS"
    echo ""
    echo -e "${YELLOW}If these are false positives, commit with:${NC}"
    echo -e "  ${BOLD}git commit --no-verify${NC}"
    echo ""
    exit 1
  fi
  echo -e "${GREEN}✓${NC} No secrets detected."
  exit 0
fi

scan_pattern() {
  local label="$1"
  local pattern="$2"

  local matches
  matches=$(echo "$ADDED_LINES" | grep -E "$pattern" 2>/dev/null || true)
  if [ -n "$matches" ]; then
    while IFS= read -r line; do
      # Skip placeholders & comments
      if echo "$line" | grep -qiE '(your-.*-here|xxxx|example|placeholder|TODO|CHANGEME)'; then
        continue
      fi
      if echo "$line" | grep -qE '^\+[[:space:]]*(#|//|/\*|\*)'; then
        continue
      fi
      local display="${line:0:120}"
      WARNINGS="${WARNINGS}\n  ${RED}✗${NC} ${BOLD}${label}${NC}"
      WARNINGS="${WARNINGS}\n    ${display}"
      FAILED=1
      return
    done <<< "$matches"
  fi
}

# AWS access key IDs
scan_pattern "AWS Access Key" 'AKIA[0-9A-Z]{16}'

# GitHub tokens
scan_pattern "GitHub Token (classic)" 'gh[pousr]_[A-Za-z0-9_]{36,}'
scan_pattern "GitHub Token (fine-grained)" 'github_pat_[A-Za-z0-9_]{22,}'

# Vercel Blob
scan_pattern "Vercel Blob Token" 'vercel_blob_rw_[A-Za-z0-9_-]{20,}'

# Slack tokens
scan_pattern "Slack Token" 'xox[bpors]-[0-9]{10,}'

# Stripe live keys
scan_pattern "Stripe Secret Key" 'sk_live_[A-Za-z0-9]{20,}'
scan_pattern "Stripe Restricted Key" 'rk_live_[A-Za-z0-9]{20,}'

# SendGrid
scan_pattern "SendGrid API Key" 'SG\.[A-Za-z0-9_-]{22,}\.[A-Za-z0-9_-]{22,}'

# NPM tokens
scan_pattern "NPM Token" 'npm_[A-Za-z0-9]{36}'

# Twilio
scan_pattern "Twilio API Key" 'SK[0-9a-fA-F]{32}'

# Private keys
scan_pattern "Private Key" '-----BEGIN.*PRIVATE KEY-----'

# Neon/Postgres connection strings with real passwords
scan_pattern "Database Connection String (Neon)" 'postgresql://[^:]+:[^@]+@[^/]*neon\.tech'

# Generic high-signal patterns: secret/password/token assignments with real values
scan_pattern "Hardcoded Secret Assignment" '(api_key|api_secret|secret_key|access_token|auth_token|private_key|API_KEY|API_SECRET|SECRET_KEY|ACCESS_TOKEN|AUTH_TOKEN|PRIVATE_KEY)[[:space:]]*[:=][[:space:]]*"[A-Za-z0-9/+=_-]{16,}"'
scan_pattern "Hardcoded Password" '(password|passwd|ADMIN_PASSWORD)[[:space:]]*[:=][[:space:]]*"[^"]{8,}"'

# Generic database URLs with passwords (non-Neon)
scan_pattern "Database URL with Credentials" '(DATABASE_URL|DB_URL|MONGO_URI)[[:space:]]*[:=][[:space:]]*"[a-z]+://[^:]+:[^@]+@'

# ── Result ──────────────────────────────────────────────────────────────
if [ "$FAILED" -eq 1 ]; then
  echo ""
  echo -e "${RED}${BOLD}🚫 COMMIT BLOCKED — potential secrets detected${NC}"
  echo -e "$WARNINGS"
  echo ""
  echo -e "${YELLOW}If these are false positives, commit with:${NC}"
  echo -e "  ${BOLD}git commit --no-verify${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}✓${NC} No secrets detected in staged changes."
exit 0
